# Browser-safe values only. These are the ONLY variables the Flutter build needs.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# GEMINI_API_KEY is NOT set here. It is a server-only Supabase Edge Function
# secret used by supabase/functions/agent — set it with:
#   supabase secrets set GEMINI_API_KEY=<key>
# Never add it to this file, Vercel env, or the web bundle.
